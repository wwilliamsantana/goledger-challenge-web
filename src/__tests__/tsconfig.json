{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "jest",
      "node"
    ],
    "typeRoots": [
      "../../node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "../../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ]
}